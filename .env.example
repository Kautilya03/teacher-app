# Postgres (used locally during testing, deprecated now)
POSTGRES_DB=guru_sikshan
POSTGRES_USER=teacher_user
POSTGRES_PASSWORD=securepass123
POSTGRES_PORT=5432

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Backend (was used earlier, entirely taken over by supabase)
DB_URL=postgresql://teacher_user:securepass123@localhost:5432/guru_sikshan

# JWT MAIN
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY_SECONDS=900
SESSION_TTL_SECONDS=86400

# SUPABASE
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_KEY_PYTHON=your_supabase_service_role_key_here

# Frontend
VITE_API_URL=http://localhost:3000
VITE_AI_URL=http://localhost:5001
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# RAGFLOW Configuration
AI_SERVICE_URL=http://localhost:5001
RAGFLOW_API_KEY=your-ragflow-api-key-here
RAGFLOW_BASE_URL=http://localhost:5001
RAGFLOW_CHAT_ID=your-ragflow-chat-id-here
RAGFLOW_MODULE_CHAT_ID=your-ragflow-module-chat-id-here
RAGFLOW_CLIENT_ID=your-ragflow-client-id
RAGFLOW_CLIENT_SECRET=your-ragflow-client-secret
RAGFLOW_DATASET_ID=your-dataset-id
RAGFLOW_DATASET_STUDENT_TEXTBOOKS=your-dataset-id
RAGFLOW_DATASET_TEACHER_TRAINING=your-dataset-id
RAGFLOW_TIMEOUT_SECONDS=600

# Chanakya Server Environment Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# NLP Pipeline Configuration
NLP_MIN_CONFIDENCE=0.3
NLP_CLARIFICATION_THRESHOLD=0.5
NLP_MAX_PROCESSING_TIME_MS=5000

# Audit Logging
ENABLE_AUDIT_LOGGING=true
LOG_RAW_INPUT=true

# Database Configuration (for checkpointing)
USE_SQLITE=false

# Model Configuration
GEMINI_MODEL=gemini-2.5-flash
MAX_OUTPUT_TOKENS=8192
TEMPERATURE=0.7

# Orchestrator Settings
MAX_RETRIES=2
CONFIDENCE_THRESHOLD=0.6
MAX_CONTEXT_MESSAGES=10
CONTEXT_EXPIRY_HOURS=24



# Sarvam AI Configuration (Optional - for Indian language STT/TTS)
SARVAM_API_KEY=your-sarvam-api-key
VITE_SARVAM_API_KEY=your-sarvam-api-key

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Query Cache Configuration
QUERY_CACHE_ENABLED=true
QUERY_CACHE_MAX_SIZE=500
QUERY_CACHE_TTL_SECONDS=3600

# Additional Integrations
TAVILY_API_KEY=your-tavily-api-key
LLAMA_CLOUD_API_KEY=your-llama-cloud-key
LLAMAPARSE_TIER=agentic_plus