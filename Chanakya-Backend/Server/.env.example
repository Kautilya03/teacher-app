# Chanakya Server Environment Variables
# ======================================
# Copy this file to .env and fill in your values

# Google Gemini API Key (Required)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# NLP Pipeline Configuration
NLP_MIN_CONFIDENCE=0.3
NLP_CLARIFICATION_THRESHOLD=0.5
NLP_MAX_PROCESSING_TIME_MS=5000

# Audit Logging
ENABLE_AUDIT_LOGGING=true
LOG_RAW_INPUT=true

# Twilio Configuration (Optional - for voice/SMS integration)
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE_NUMBER
TWILIO_WEBHOOK_URL=https://your-domain.com

# Sarvam AI Configuration (Optional - for Indian language STT/TTS)
# Get from: https://www.sarvam.ai/
SARVAM_API_KEY=YOUR_API_SUBSCRIPTION_KEY

# Tavily API Key (Optional - for web search MCP)
# Get from: https://www.tavily.com/
TAVILY_API_KEY=your-tavily-api-key

# Query cache (repeated identical queries return cached response, no LLM call)
QUERY_CACHE_ENABLED=true
QUERY_CACHE_MAX_SIZE=500
QUERY_CACHE_TTL_SECONDS=3600

# Future: Database (for audit logs)
# DATABASE_URL=postgresql://user:password@localhost:5432/chanakya

# Future: Redis (for caching)
# REDIS_URL=redis://localhost:6379
